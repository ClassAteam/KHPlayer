If:
  PathMatch: "android/.*"
Diagnostics:
  Suppress: "*"

---

CompileFlags:
  # Use compile_commands.json from build directory
  CompilationDatabase: build

Index:
  # Don't index CMake build dirs or Android-specific code (cross-compiled, host LSP can't handle it)
  Index:
    Background:
      PathExclude: ["build/.*", "build-.*/.*", "third_party/.*", "android/.*"]

Diagnostics:
  # Disable some overly aggressive warnings
  UnusedIncludes: Strict

  # Clang-Tidy checks
  ClangTidy:
    Add:
      - bugprone-*           # Only keep bug-prone checks (most important)
      - performance-*         # Performance issues
      - clang-analyzer-*      # Static analyzer (real bugs)
    Remove:
      # Remove all the noisy readability/style checks
      - bugprone-easily-swappable-parameters
      - bugprone-narrowing-conversions  # Too noisy with FFmpeg APIs
      - bugprone-implicit-widening-of-multiplication-result

InlayHints:
  Enabled: Yes
  ParameterNames: Yes
  DeducedTypes: Yes

Hover:
  ShowAKA: Yes

Completion:
  AllScopes: Yes
